---
layout: base.njk
pageTitle: "צור קשר"
permalink: "/contact/"
pageDescription: "צרו קשר עם נועה ארנטל — פסיכותרפיסטית ועו\"ס קלינית. טופס פנייה, טלפון או וואטסאפ. שיחת היכרות ראשונית ללא התחייבות, מענה תוך יום עסקים."
---
{% set root = page.url | rootPath %}
<section class="page-hero">
  <div class="band-inner narrow">
    <span class="eyebrow">{{ contactPage.eyebrow }}</span>
    <h1>{{ contactPage.title }}</h1>
  </div>
</section>
<section class="band band-contact">
  <div class="band-inner two-col contact-block">
    <div>
      <p>{{ contactPage.intro }}</p>
      <div class="contact-direct">
        <a href="tel:{{ business.phoneIntl }}" class="contact-line"><span aria-hidden="true">📞</span> {{ business.phone }}</a>
        <a href="https://wa.me/{{ business.whatsapp }}?text=%D7%94%D7%99%D7%99%20%D7%A0%D7%95%D7%A2%D7%94%2C%20%D7%94%D7%92%D7%A2%D7%AA%D7%99%20%D7%9E%D7%94%D7%90%D7%AA%D7%A8%20%D7%A9%D7%9C%D7%9A%20%D7%95%D7%90%D7%A9%D7%9E%D7%97%20%D7%9C%D7%AA%D7%90%D7%9D%20%D7%A9%D7%99%D7%97%D7%AA%20%D7%94%D7%99%D7%9B%D7%A8%D7%95%D7%AA" class="contact-line" target="_blank" rel="noopener"><span aria-hidden="true">💬</span> שליחת הודעת WhatsApp</a>
        <a href="{{ business.facebook }}" class="contact-line" target="_blank" rel="noopener"><span aria-hidden="true">👋</span> עמוד הפייסבוק שלי</a>
      </div>
      <p style="margin-top:18px;color:var(--muted);font-size:.92rem">{{ business.location }}<br>{{ business.license }} · <a href="{{ business.licenseVerifyUrl }}" target="_blank" rel="noopener" style="text-decoration:underline">לאימות בפנקס הרשמי</a></p>
    </div>
    <form class="contact-form" onsubmit="return handleContact(event)">
      <input type="checkbox" name="botcheck" class="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true">
      <label>שם מלא *<input type="text" name="name" required></label>
      <label>טלפון *<input type="tel" name="phone" required></label>
      <label>מייל<input type="email" name="email"></label>
      <label>איך אוכל לעזור לך?<textarea name="message" rows="4"></textarea></label>
      <label class="consent"><input type="checkbox" required> אני מאשר/ת את <a href="{{ root }}/privacy-policy/">מדיניות הפרטיות</a></label>
      <button type="submit" class="btn btn-primary btn-block">שליחה</button>
      <p class="form-note">{{ contactPage.formNote }}</p>
      <p class="form-msg" hidden></p>
    </form>
  </div>
</section>
