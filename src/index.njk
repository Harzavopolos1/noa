---
layout: base.njk
pageTitle: ""
pageDescription: "נועה ארנטל — עו\"ס קלינית (MSW) ופסיכותרפיסטית מוסמכת. טיפול נפשי בקליניקה בתל אביב ואונליין מכל מקום. מנהלת מקצועית ארצית של שירות פסיכותרפיה מקוונת. שיחת היכרות ללא התחייבות."
---
{% set root = page.url | rootPath %}

<!-- HERO -->
<section class="hero">
  <svg class="hero-blob" viewBox="0 0 200 200" fill="currentColor" aria-hidden="true"><path d="M44,-58C56,-49,63,-33,67,-16C70,1,69,19,61,33C53,47,38,57,21,63C4,69,-15,71,-32,64C-49,57,-64,41,-69,22C-74,3,-69,-19,-58,-35C-47,-51,-30,-61,-12,-65C6,-69,24,-67,44,-58Z" transform="translate(100 100)"/></svg>
  <svg class="hero-blob-2" viewBox="0 0 200 200" fill="currentColor" aria-hidden="true"><path d="M38,-52C50,-43,60,-31,65,-16C70,-1,69,16,61,29C53,42,38,52,21,59C4,66,-14,69,-31,63C-48,57,-63,41,-69,22C-75,3,-71,-18,-61,-34C-50,-50,-33,-60,-15,-64C3,-68,21,-66,38,-52Z" transform="translate(100 100)"/></svg>

  <div class="hero-inner">
    <div class="hero-text reveal">
      <span class="eyebrow">{{ home.hero.eyebrow }}</span>
      <h1>{{ home.hero.titleLine1 }}<br><span class="accent">{{ home.hero.titleAccent }}</span></h1>
      <p class="lead">{{ home.hero.lead }}</p>
      <p>{{ home.hero.sub }}</p>
      <div class="hero-cta">
        <a href="{{ root }}/contact/" class="btn btn-primary">{{ home.hero.ctaPrimary }}</a>
        <a href="{{ root }}/about/" class="btn btn-ghost">{{ home.hero.ctaSecondary }}</a>
      </div>
    </div>

    <div class="hero-photo reveal d2">
      <div class="photo-stack">
        <div class="photo-frame">
          <img src="{{ root }}{{ home.hero.photo }}" alt="{{ home.hero.photoAlt }}">
        </div>
        <div class="badge"><strong>{{ home.hero.badgeTitle }}</strong><span>{{ home.hero.badgeSub }}</span></div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<div class="trust-strip reveal">
  {%- for item in home.trustStrip %}
  <span>{{ item }}</span>
  {%- endfor %}
</div>

<!-- ONLINE THERAPY -->
<section class="band" id="online">
  <div class="band-inner two-col">
    <div class="reveal">
      <span class="eyebrow">{{ home.online.eyebrow }}</span>
      <h2>{{ home.online.title }}</h2>
      <p>{{ home.online.p1 }}</p>
      <p>{{ home.online.p2 }}</p>
      <a href="{{ root }}/contact/" class="btn btn-primary" style="margin-top:22px">{{ home.online.cta }}</a>
    </div>
    <div class="reveal d2">
      <ul class="check-list">
        {%- for item in home.online.checklist %}
        <li>{{ item }}</li>
        {%- endfor %}
      </ul>
    </div>
  </div>
</section>

<!-- METHODS -->
<section class="band band-soft" id="methods">
  <div class="band-inner">
    <div class="section-head reveal">
      <span class="eyebrow" style="justify-content:center">{{ home.methods.eyebrow }}</span>
      <h2>{{ home.methods.title }}</h2>
      <p>{{ home.methods.sub }}</p>
    </div>
    <div class="methods-grid">
      {%- for card in home.methods.cards %}
      <div class="method-card reveal{{ ['', ' d1', ' d2'][loop.index0 % 3] }}"><span class="method-tag">{{ card.tag }}</span><p>{{ card.text }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="band">
  <div class="band-inner">
    <div class="section-head reveal">
      <span class="eyebrow" style="justify-content:center">{{ home.steps.eyebrow }}</span>
      <h2>{{ home.steps.title }}</h2>
    </div>
    <div class="steps">
      {%- for step in home.steps.items %}
      <div class="step reveal{{ ['', ' d1', ' d2'][loop.index0 % 3] }}"><span class="connector"></span><span class="num">0{{ loop.index }}</span><h3>{{ step.title }}</h3><p>{{ step.text }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- PRACTICAL INFO -->
<section class="band band-soft" id="practical">
  <div class="band-inner">
    <div class="section-head reveal">
      <span class="eyebrow" style="justify-content:center">{{ home.practical.eyebrow }}</span>
      <h2>{{ home.practical.title }}</h2>
    </div>
    <div class="practical-grid reveal d1">
      {%- for item in home.practical.items %}
      <div class="practical-item"><strong>{{ item.label }}</strong><span>{{ item.text }}</span></div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- QUOTE / APPROACH -->
<section class="band band-quote reveal">
  <div class="band-inner narrow">
    <span class="mark">”</span>
    <blockquote>{{ home.quote.text }}</blockquote>
    <cite>{{ home.quote.cite }}</cite>
  </div>
</section>

<!-- AREAS -->
<section class="band band-cream" id="areas">
  <div class="band-inner">
    <div class="section-head reveal">
      <span class="eyebrow" style="justify-content:center">{{ home.areas.eyebrow }}</span>
      <h2>{{ home.areas.title }}</h2>
      <p>{{ home.areas.sub }}</p>
    </div>
    <div class="areas-grid reveal d1">
      {%- for pill in home.areas.pills %}
      <span class="area-pill">{{ pill }}</span>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="band" id="faq">
  <div class="band-inner">
    <div class="section-head reveal">
      <span class="eyebrow" style="justify-content:center">{{ home.faqSection.eyebrow }}</span>
      <h2>{{ home.faqSection.title }}</h2>
    </div>
    <div class="faq-list reveal d1">
      {%- for f in home.faqSection.items %}
      <details class="faq-item">
        <summary>{{ f.q }}</summary>
        <div class="faq-body">{{ f.a }}</div>
      </details>
      {%- endfor %}
    </div>
  </div>
</section>

<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
{%- for f in home.faqSection.items %}
{"@type":"Question","name":{{ f.q | dump | safe }},"acceptedAnswer":{"@type":"Answer","text":{{ f.a | dump | safe }}}}{{ "," if not loop.last }}
{%- endfor %}
]}</script>

<!-- CONTACT -->
<section class="band band-contact" id="contact">
  <div class="band-inner two-col contact-block">
    <div class="reveal">
      <span class="eyebrow">{{ home.contact.eyebrow }}</span>
      <h2>{{ home.contact.title }}</h2>
      <p>{{ home.contact.text }}</p>
      <div class="contact-direct">
        <a href="tel:{{ business.phoneIntl }}" class="contact-line"><span aria-hidden="true">📞</span> {{ business.phone }}</a>
        <a href="https://wa.me/{{ business.whatsapp }}?text=%D7%94%D7%99%D7%99%20%D7%A0%D7%95%D7%A2%D7%94%2C%20%D7%94%D7%92%D7%A2%D7%AA%D7%99%20%D7%9E%D7%94%D7%90%D7%AA%D7%A8%20%D7%A9%D7%9C%D7%9A%20%D7%95%D7%90%D7%A9%D7%9E%D7%97%20%D7%9C%D7%AA%D7%90%D7%9D%20%D7%A9%D7%99%D7%97%D7%AA%20%D7%94%D7%99%D7%9B%D7%A8%D7%95%D7%AA" class="contact-line" target="_blank" rel="noopener"><span aria-hidden="true">💬</span> שליחת הודעת WhatsApp</a>
        <a href="{{ business.facebook }}" class="contact-line" target="_blank" rel="noopener"><span aria-hidden="true">👋</span> עמוד הפייסבוק שלי</a>
        <a href="{{ business.linkedin }}" class="contact-line" target="_blank" rel="noopener"><span aria-hidden="true">🔗</span> הפרופיל המקצועי שלי ב‑LinkedIn</a>
      </div>
      <p style="margin-top:18px;color:var(--muted);font-size:.92rem">{{ business.location }}<br>{{ business.license }}</p>
    </div>
    <form class="contact-form reveal d2" onsubmit="return handleContact(event)">
      <input type="checkbox" name="botcheck" class="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true">
      <label>שם מלא *<input type="text" name="name" required></label>
      <label>טלפון *<input type="tel" name="phone" required></label>
      <label>מייל<input type="email" name="email"></label>
      <label>איך אוכל לעזור לך?<textarea name="message" rows="4"></textarea></label>
      <label class="consent"><input type="checkbox" required> אני מאשר/ת את <a href="{{ root }}/privacy-policy/">מדיניות הפרטיות</a></label>
      <button type="submit" class="btn btn-primary btn-block">שליחה</button>
      <p class="form-note">{{ contactPage.formNote }}</p>
      <p class="form-msg" hidden></p>
    </form>
  </div>
</section>
