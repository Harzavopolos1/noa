<!DOCTYPE html>
<html lang="{{ site.lang }}" dir="{{ site.dir }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% set fullTitle %}{% if pageTitle %}{{ pageTitle }} — {{ business.therapistName }}{% else %}{{ site.title }}{% endif %}{% endset %}
  <title>{{ fullTitle }}</title>
  <meta name="description" content="{{ pageDescription or site.description }}">
  {% set root = page.url | rootPath %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph / social sharing (WhatsApp, Facebook, LinkedIn) -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:title" content="{{ fullTitle }}">
  <meta property="og:description" content="{{ pageDescription or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}{{ site.ogImage }}">
  <meta property="og:locale" content="he_IL">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ fullTitle }}">
  <meta name="twitter:description" content="{{ pageDescription or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ site.ogImage }}">

  <link rel="icon" type="image/png" href="{{ root }}/assets/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;500;600;700&family=Frank+Ruhl+Libre:wght@400;500;700;900&display=swap">
  <link rel="stylesheet" href="{{ root }}/assets/css/style.css">

  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "{{ site.url }}/#noa",
        "name": "{{ business.therapistName }}",
        "jobTitle": "עובדת סוציאלית קלינית (MSW), פסיכותרפיסטית מוסמכת ומדריכה קלינית",
        "image": "{{ site.url }}{{ site.ogImage }}",
        "url": "{{ site.url }}/",
        "telephone": "{{ business.phoneIntl }}",
        "knowsLanguage": ["he", "en"],
        "sameAs": ["{{ business.facebook }}", "{{ business.linkedin }}"],
        "hasCredential": {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "רישום בפנקס העובדים הסוציאליים",
          "credentialNumber": "37029",
          "recognizedBy": { "@type": "GovernmentOrganization", "name": "משרד הרווחה והביטחון החברתי", "url": "{{ business.licenseVerifyUrl }}" }
        }
      },
      {
        "@type": "ProfessionalService",
        "@id": "{{ site.url }}/#practice",
        "name": "{{ site.title }}",
        "description": "{{ site.description }}",
        "url": "{{ site.url }}/",
        "image": "{{ site.url }}{{ site.ogImage }}",
        "telephone": "{{ business.phoneIntl }}",
        "address": { "@type": "PostalAddress", "addressLocality": "תל אביב–יפו", "addressCountry": "IL" },
        "areaServed": "ישראל",
        "founder": { "@id": "{{ site.url }}/#noa" }
      }
    ]
  }
  </script>
  {% endif %}
</head>
<body>

  <a class="skip-link" href="#content">דילוג לתוכן</a>

  <!-- Top consultation strip -->
  <div class="top-strip">
    <span>השאירו פרטים לשיחת ייעוץ ראשונית — ללא התחייבות</span>
    <a href="{{ root }}/contact/" class="top-strip-cta">לתיאום שיחה</a>
  </div>

  <!-- Header -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="{{ root }}/" class="brand">
        <span class="brand-name">{{ business.therapistName }}</span>
        <span class="brand-sub">{{ business.profession }}</span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-label="תפריט" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="main-nav" id="mainNav" aria-label="ניווט ראשי">
        {% for item in site.nav %}
          {% if item.children %}
          {% set parentActive = false %}
          {% for c in item.children %}{% if page.url == c.url %}{% set parentActive = true %}{% endif %}{% endfor %}
          <div class="nav-item has-children">
            <a href="{{ root }}{{ item.url }}" class="nav-parent{% if parentActive or (item.url != '/#areas' and item.url in page.url) %} active{% endif %}">{{ item.label }}<span class="caret" aria-hidden="true">▾</span></a>
            <div class="nav-dropdown">
              {% if item.overview %}<a href="{{ root }}{{ item.url }}">{{ item.overview }}</a>{% endif %}
              {% for c in item.children %}
              <a href="{{ root }}{{ c.url }}"{% if page.url == c.url %} class="active"{% endif %}>{{ c.label }}</a>
              {% endfor %}
            </div>
          </div>
          {% else %}
          <a href="{{ root }}{{ item.url }}"{% if page.url == item.url %} class="active"{% endif %}>{{ item.label }}</a>
          {% endif %}
        {% endfor %}
      </nav>
    </div>
  </header>

  <main id="content">
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">

      <div class="footer-col footer-about">
        <div class="footer-brand">{{ business.therapistName }}</div>
        <p>{{ business.profession }}. עבורי זו זכות גדולה ללוות אנשים בתהליך של היכרות עם עצמם ושיפור איכות חייהם הרגשית והחברתית.</p>
        <p style="font-size:.85rem;opacity:.85">{{ business.license }} · <a href="{{ business.licenseVerifyUrl }}" target="_blank" rel="noopener" style="text-decoration:underline">לאימות בפנקס העובדים הסוציאליים</a></p>
        <div class="footer-contact">
          <a href="tel:{{ business.phoneIntl }}">{{ business.phone }}</a>
          <a href="https://wa.me/{{ business.whatsapp }}?text=%D7%94%D7%99%D7%99%20%D7%A0%D7%95%D7%A2%D7%94%2C%20%D7%94%D7%92%D7%A2%D7%AA%D7%99%20%D7%9E%D7%94%D7%90%D7%AA%D7%A8%20%D7%A9%D7%9C%D7%9A%20%D7%95%D7%90%D7%A9%D7%9E%D7%97%20%D7%9C%D7%AA%D7%90%D7%9D%20%D7%A9%D7%99%D7%97%D7%AA%20%D7%94%D7%99%D7%9B%D7%A8%D7%95%D7%AA" target="_blank" rel="noopener">WhatsApp</a>
          {% if business.facebook %}<a href="{{ business.facebook }}" target="_blank" rel="noopener">פייסבוק</a>{% endif %}
        </div>
      </div>

      <div class="footer-col">
        <h3>טיפולים</h3>
        <ul>
          {% for s in site.services %}
          <li><a href="{{ root }}{{ s.url }}">{{ s.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-col">
        <h3>קישורים</h3>
        <ul>
          <li><a href="{{ root }}/about/">אודות</a></li>
          <li><a href="{{ root }}/articles/">מאמרים</a></li>
          <li><a href="{{ root }}/#areas">תחומי טיפול</a></li>
          <li><a href="{{ root }}/contact/">צור קשר</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3>מידע</h3>
        <ul>
          <li><a href="{{ root }}/privacy-policy/">מדיניות פרטיות</a></li>
          <li><a href="{{ root }}/terms/">תנאי שימוש</a></li>
          <li><a href="{{ root }}/accessibility/">הצהרת נגישות</a></li>
        </ul>
      </div>

    </div>
    <div class="footer-bottom">
      <span>© {{ business.therapistName }} · כל הזכויות שמורות</span>
    </div>
  </footer>

  <!-- WhatsApp floating button -->
  <a href="https://wa.me/{{ business.whatsapp }}?text=%D7%94%D7%99%D7%99%20%D7%A0%D7%95%D7%A2%D7%94%2C%20%D7%94%D7%92%D7%A2%D7%AA%D7%99%20%D7%9E%D7%94%D7%90%D7%AA%D7%A8%20%D7%A9%D7%9C%D7%9A%20%D7%95%D7%90%D7%A9%D7%9E%D7%97%20%D7%9C%D7%AA%D7%90%D7%9D%20%D7%A9%D7%99%D7%97%D7%AA%20%D7%94%D7%99%D7%9B%D7%A8%D7%95%D7%AA" class="wa-float" target="_blank" rel="noopener" aria-label="שליחת הודעת WhatsApp">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor" aria-hidden="true">
      <path d="M16 .5C7.4.5.5 7.4.5 16c0 2.8.8 5.5 2.2 7.9L.4 31.6l7.9-2.1c2.3 1.3 4.9 1.9 7.7 1.9 8.6 0 15.5-6.9 15.5-15.5S24.6.5 16 .5zm0 28.3c-2.5 0-4.9-.7-7-1.9l-.5-.3-4.7 1.2 1.3-4.6-.3-.5c-1.4-2.2-2.1-4.7-2.1-7.2C2.9 8.7 8.8 2.9 16 2.9S29.1 8.7 29.1 16 23.2 28.8 16 28.8zm7.2-9.6c-.4-.2-2.3-1.1-2.7-1.3-.4-.1-.6-.2-.9.2-.3.4-1 1.3-1.2 1.5-.2.2-.4.3-.8.1-.4-.2-1.7-.6-3.2-2-1.2-1-2-2.3-2.2-2.7-.2-.4 0-.6.2-.8.2-.2.4-.4.6-.7.2-.2.3-.4.4-.7.1-.3 0-.5 0-.7-.1-.2-.9-2.1-1.2-2.9-.3-.8-.6-.7-.9-.7h-.7c-.2 0-.6.1-.9.5-.3.4-1.2 1.2-1.2 2.9 0 1.7 1.2 3.3 1.4 3.6.2.2 2.4 3.7 5.9 5.2.8.4 1.5.6 2 .7.8.3 1.6.2 2.2.1.7-.1 2.3-.9 2.6-1.8.3-.9.3-1.6.2-1.8-.1-.1-.3-.2-.7-.4z"/>
    </svg>
  </a>

  <script src="{{ root }}/assets/js/app.js"></script>
  <script src="{{ root }}/assets/js/assist.js" defer></script>
  {% if site.cfAnalyticsToken %}
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "{{ site.cfAnalyticsToken }}"}'></script>
  {% endif %}
</body>
</html>
