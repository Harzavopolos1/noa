---
layout: base.njk
pageTitle: "אודות"
permalink: "/about/"
---
{% set root = page.url | rootPath %}
<section class="page-hero">
  <div class="band-inner narrow">
    <span class="eyebrow" style="justify-content:center">{{ aboutPage.eyebrow }}</span>
    <h1>{{ aboutPage.title }}</h1>
    <p style="color:var(--muted);margin-top:10px">{{ aboutPage.subtitle }}</p>
  </div>
</section>

<section class="band">
  <div class="band-inner two-col" style="align-items:start">
    <div class="reveal prose">
      {%- for p in aboutPage.paragraphs %}
      <p>{{ p }}</p>
      {%- endfor %}
      <a href="{{ root }}/contact/" class="btn btn-primary">{{ aboutPage.ctaText }}</a>
    </div>
    <div class="reveal d1">
      <div class="photo-stack" style="max-width:320px;margin-inline:auto">
        <div class="photo-frame"><img src="{{ root }}{{ aboutPage.photo }}" alt="{{ aboutPage.photoAlt }}"></div>
      </div>
    </div>
  </div>
</section>

<section class="band band-soft">
  <div class="band-inner narrow">
    <h2 class="reveal">{{ aboutPage.approach.title }}</h2>
    <p class="reveal" style="color:var(--muted)">{{ aboutPage.approach.text }}</p>
  </div>
</section>

<section class="band">
  <div class="band-inner narrow">
    <h2 class="reveal">{{ aboutPage.education.title }}</h2>
    <ul class="check-list reveal" style="margin-top:18px">
      {%- for item in aboutPage.education.items %}
      <li>{{ item }}</li>
      {%- endfor %}
    </ul>
    <p class="reveal" style="margin-top:20px;color:var(--muted)"><strong style="color:var(--ink)">{{ aboutPage.education.extraLabel }}</strong> {{ aboutPage.education.extraText }}</p>
  </div>
</section>

<section class="band band-soft">
  <div class="band-inner narrow">
    <h2 class="reveal">{{ aboutPage.experience.title }}</h2>
    <ul class="check-list reveal" style="margin-top:18px">
      {%- for item in aboutPage.experience.items %}
      <li>{{ item }}</li>
      {%- endfor %}
    </ul>
    <a href="{{ root }}/contact/" class="btn btn-primary" style="margin-top:26px">{{ aboutPage.experience.ctaText }}</a>
  </div>
</section>
